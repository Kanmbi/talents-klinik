<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Talents Klinik — AI Career Intelligence Platform by RésuméKlinik</title>
<meta name="description" content="Nigeria's first AI-powered end-to-end career platform. CV assessment, skill gap analysis, personalised training, and job matching.">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ══ TOKENS ══ */
:root{
  --g:#8DC63F;--gd:#6BA528;--g2:#C5E87A;--gl:rgba(141,198,63,0.12);
  --n:#1C2E4A;--n2:#243856;--n3:#0E1B2C;
  --bg:#0C1220;--bg2:#111927;--bg3:#162030;
  --card:#18243A;--card2:#1E2E48;
  --w:#FFFFFF;--cr:#F7FAF2;
  --t:#EDF2FF;--t2:#8A9FCA;--t3:#4E6490;
  --bd:rgba(255,255,255,0.07);--bd2:rgba(255,255,255,0.12);
  --teal:#10B981;--teal-d:rgba(16,185,129,0.12);
  --amber:#F59E0B;--amber-d:rgba(245,158,11,0.12);
  --rose:#F43F5E;--rose-d:rgba(244,63,94,0.12);
  --purple:#8B5CF6;--purple-d:rgba(139,92,246,0.12);
  --r:14px;--rs:10px;
  --sh:0 4px 24px rgba(0,0,0,0.25);
  --shg:0 6px 24px rgba(141,198,63,0.25);
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t);min-height:100vh;overflow-x:hidden}
h1,h2,h3,h4{font-family:'Cormorant Garamond',serif;line-height:1.2}
a{text-decoration:none;color:inherit}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-thumb{background:var(--gd);border-radius:2px}

/* ══ SCREENS ══ */
.screen{display:none;min-height:100vh}
.screen.active{display:flex;flex-direction:column}

/* ══ AUTH SCREEN ══ */
#auth{background:var(--bg);align-items:center;justify-content:center;padding:20px;position:relative;overflow:hidden}
.auth-bg{position:absolute;inset:0;pointer-events:none}
.auth-orb{position:absolute;border-radius:50%;filter:blur(80px)}
.auth-box{background:var(--card);border:1px solid var(--bd2);border-radius:24px;padding:40px;width:100%;max-width:420px;position:relative;z-index:2;box-shadow:var(--sh)}
.auth-logo{text-align:center;margin-bottom:28px}
.auth-brand{font-family:'Cormorant Garamond',serif;font-size:14px;font-weight:600;color:var(--t3);letter-spacing:.08em;text-transform:uppercase;margin-bottom:4px}
.auth-title{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:700;color:var(--t);margin-bottom:4px}
.auth-sub{font-size:13px;color:var(--t3);line-height:1.6}
.auth-tabs{display:flex;background:var(--bg3);border-radius:var(--rs);padding:4px;margin:24px 0;gap:4px}
.auth-tab{flex:1;padding:9px;border-radius:8px;font-size:13px;font-weight:500;cursor:pointer;text-align:center;color:var(--t3);transition:all .2s}
.auth-tab.active{background:var(--card2);color:var(--t);box-shadow:0 1px 4px rgba(0,0,0,0.3)}
.auth-form{display:none}.auth-form.active{display:block}
.fl{font-size:11px;font-weight:600;color:var(--t3);display:block;margin-bottom:5px;text-transform:uppercase;letter-spacing:.06em}
.fi{width:100%;background:var(--bg3);border:1px solid var(--bd);border-radius:var(--rs);padding:11px 14px;color:var(--t);font-size:14px;font-family:'DM Sans',sans-serif;outline:none;transition:all .2s;margin-bottom:14px}
.fi:focus{border-color:var(--g);box-shadow:0 0 0 3px rgba(141,198,63,0.1)}
.fi::placeholder{color:var(--t3)}
.fi-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
select.fi{cursor:pointer;appearance:none;background-image:url("data:image/svg+xml,%3Csvg width='10' height='6' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%234E6490' stroke-width='1.5' fill='none'/%3E%3C/svg%3E");background-repeat:no-repeat;background-position:right 12px center;padding-right:32px}
select.fi option{background:var(--card)}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:12px 22px;border-radius:var(--rs);font-size:14px;font-weight:500;cursor:pointer;border:none;font-family:'DM Sans',sans-serif;transition:all .2s;letter-spacing:.01em}
.btn-g{background:var(--g);color:var(--n);font-weight:600}
.btn-g:hover{background:var(--g2);transform:translateY(-1px);box-shadow:var(--shg)}
.btn-o{background:transparent;border:1px solid var(--bd2);color:var(--t2)}
.btn-o:hover{border-color:var(--g);color:var(--g)}
.btn-fw{width:100%}
.btn-sm{padding:8px 16px;font-size:13px}
.auth-err{background:var(--rose-d);border:1px solid rgba(244,63,94,0.2);border-radius:8px;padding:10px 14px;font-size:13px;color:var(--rose);margin-bottom:14px;display:none}
.auth-footer{text-align:center;font-size:12px;color:var(--t3);margin-top:16px}
.auth-footer a{color:var(--g)}
.divider-or{display:flex;align-items:center;gap:12px;margin:16px 0;color:var(--t3);font-size:12px}
.divider-or::before,.divider-or::after{content:'';flex:1;height:1px;background:var(--bd)}

/* ══ APP SHELL ══ */
#app{background:var(--bg);flex-direction:row}
.sidebar{width:240px;background:var(--card);border-right:1px solid var(--bd);display:flex;flex-direction:column;position:fixed;top:0;left:0;height:100vh;z-index:100;transition:transform .3s}
.sb-header{padding:18px 16px 14px;border-bottom:1px solid var(--bd)}
.sb-brand{font-size:9px;text-transform:uppercase;letter-spacing:.12em;color:var(--t3);font-weight:600;margin-bottom:2px}
.sb-logo{font-family:'Cormorant Garamond',serif;font-size:18px;font-weight:700;color:var(--t);line-height:1}
.sb-logo span{color:var(--g)}
.sb-tag{font-size:10px;color:var(--t3);font-style:italic;margin-top:2px}
.sb-nav{flex:1;padding:12px 8px;overflow-y:auto}
.sb-section{margin-bottom:18px}
.sb-label{font-size:9px;text-transform:uppercase;letter-spacing:.12em;color:var(--t3);font-weight:600;padding:0 10px;margin-bottom:4px}
.ni{display:flex;align-items:center;gap:9px;padding:9px 10px;border-radius:var(--rs);cursor:pointer;color:var(--t3);font-size:13px;transition:all .15s;margin-bottom:1px;border:none;background:none;width:100%;text-align:left;font-family:'DM Sans',sans-serif;position:relative}
.ni:hover{background:var(--bg3);color:var(--t)}
.ni.active{background:rgba(141,198,63,0.1);color:var(--g);border:1px solid rgba(141,198,63,0.15)}
.ni svg{width:15px;height:15px;flex-shrink:0}
.ni-badge{margin-left:auto;background:var(--g);color:var(--n);font-size:9px;font-weight:700;padding:2px 7px;border-radius:10px}
.ni-phase{font-size:9px;color:var(--t3);padding:3px 8px;border-radius:10px;background:var(--bg3);margin-left:auto}
.ni.active .ni-phase{background:rgba(141,198,63,0.15);color:var(--gd)}
.sb-user{padding:12px 14px;border-top:1px solid var(--bd)}
.su-inner{display:flex;align-items:center;gap:10px}
.su-av{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,var(--g),var(--gd));display:flex;align-items:center;justify-content:center;font-family:'Cormorant Garamond',serif;font-size:13px;font-weight:700;color:var(--n);flex-shrink:0}
.su-name{font-size:13px;font-weight:500;color:var(--t);line-height:1.2}
.su-plan{font-size:10px;color:var(--t3)}
.su-logout{margin-left:auto;background:none;border:none;cursor:pointer;color:var(--t3);transition:color .15s;padding:4px}
.su-logout:hover{color:var(--rose)}
.su-logout svg{width:14px;height:14px;stroke:currentColor;fill:none}

/* ══ MAIN CONTENT ══ */
.main{margin-left:240px;flex:1;min-height:100vh;display:flex;flex-direction:column}
.topbar{background:var(--bg2);border-bottom:1px solid var(--bd);padding:0 28px;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;flex-shrink:0}
.tb-page{font-family:'Cormorant Garamond',serif;font-size:17px;font-weight:700;color:var(--t)}
.tb-right{display:flex;align-items:center;gap:10px}
.tb-phase{display:flex;align-items:center;gap:6px;background:var(--bg3);border:1px solid var(--bd);border-radius:20px;padding:5px 12px;font-size:12px;color:var(--t3)}
.tb-phase-dot{width:6px;height:6px;border-radius:50%;background:var(--g);flex-shrink:0}
.content{padding:28px;flex:1;overflow-y:auto}

/* ══ PAGES ══ */
.page{display:none;animation:fadeUp .25s ease}
.page.active{display:block}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}

/* ══ CARDS ══ */
.card{background:var(--card);border:1px solid var(--bd);border-radius:var(--r);padding:22px}
.card-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.card-title{font-family:'Cormorant Garamond',serif;font-size:16px;font-weight:700;color:var(--t)}
.card-sub{font-size:11px;color:var(--t3);margin-top:2px}

/* STAT CARDS */
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:22px}
.stat{background:var(--card);border:1px solid var(--bd);border-radius:var(--r);padding:16px}
.stat-i{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:10px}
.stat-i svg{width:17px;height:17px}
.stat-n{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:700;color:var(--t);line-height:1;margin-bottom:3px}
.stat-l{font-size:12px;color:var(--t3)}
.stat-d{font-size:11px;margin-top:5px;font-weight:500}

/* GRID LAYOUTS */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px}
.gm{display:grid;grid-template-columns:2fr 1fr;gap:18px}
.gs{display:grid;grid-template-columns:1fr 2fr;gap:18px}

/* PROGRESS BAR */
.pb{height:5px;background:var(--bg3);border-radius:3px;overflow:hidden}
.pf{height:100%;border-radius:3px;transition:width 1.2s ease}

/* BADGE */
.badge{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600}
.badge-g{background:var(--gl);color:var(--g)}
.badge-a{background:var(--amber-d);color:var(--amber)}
.badge-t{background:var(--teal-d);color:var(--teal)}
.badge-r{background:var(--rose-d);color:var(--rose)}
.badge-p{background:var(--purple-d);color:var(--purple)}
.badge-n{background:rgba(255,255,255,0.05);color:var(--t3)}

/* RING */
.ring{position:relative;flex-shrink:0}
.ring svg{transform:rotate(-90deg);display:block}
.ring-inner{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}
.ring-n{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:700;line-height:1}
.ring-l{font-size:9px;color:var(--t3);text-transform:uppercase;letter-spacing:.06em;margin-top:2px}

/* PHASE BANNER */
.phase-banner{background:linear-gradient(135deg,rgba(141,198,63,0.07),rgba(139,92,246,0.05));border:1px solid rgba(141,198,63,0.15);border-radius:var(--r);padding:16px 20px;margin-bottom:22px;display:flex;align-items:center;gap:14px}
.pb-num{width:38px;height:38px;border-radius:50%;background:var(--g);color:var(--n);font-family:'Cormorant Garamond',serif;font-size:16px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:var(--shg)}
.pb-title{font-family:'Cormorant Garamond',serif;font-size:15px;font-weight:700;color:var(--t)}
.pb-sub{font-size:12px;color:var(--t3)}

/* JOB CARD */
.jc{display:flex;align-items:center;gap:12px;padding:13px 0;border-bottom:1px solid var(--bd);cursor:pointer;transition:opacity .15s}
.jc:last-child{border:none}
.jc:hover{opacity:.8}
.jc-logo{width:42px;height:42px;background:var(--bg3);border:1px solid var(--bd);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.jc-info{flex:1}
.jc-title{font-size:14px;font-weight:500;color:var(--t);margin-bottom:2px}
.jc-co{font-size:12px;color:var(--t3)}
.jc-tags{display:flex;gap:5px;margin-top:5px;flex-wrap:wrap}
.jc-match{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:700;color:var(--g);flex-shrink:0}

/* QUIZ */
.qq{background:var(--bg3);border:1px solid var(--bd);border-radius:var(--r);padding:18px;margin-bottom:12px}
.qq-t{font-family:'Cormorant Garamond',serif;font-size:15px;font-weight:700;color:var(--t);margin-bottom:12px}
.qo{display:flex;align-items:center;gap:10px;padding:10px 13px;border:1px solid var(--bd);border-radius:var(--rs);cursor:pointer;font-size:13.5px;color:var(--t2);transition:all .15s;margin-bottom:7px}
.qo:hover,.qo.sel{border-color:var(--g);background:rgba(141,198,63,0.07);color:var(--g)}
.qo:last-child{margin:0}
.qd{width:16px;height:16px;border-radius:50%;border:1.5px solid var(--bd2);flex-shrink:0;transition:all .15s}
.qo.sel .qd{background:var(--g);border-color:var(--g);box-shadow:0 0 0 3px rgba(141,198,63,0.2)}

/* SKILL TAGS */
.stag{display:inline-flex;align-items:center;gap:4px;padding:5px 11px;border:1px solid var(--bd);border-radius:20px;font-size:12px;cursor:pointer;transition:all .15s;margin:3px}
.stag.hv{background:var(--teal-d);border-color:rgba(16,185,129,.25);color:var(--teal)}
.stag.ms{background:var(--rose-d);border-color:rgba(244,63,94,.25);color:var(--rose)}
.stag.ln{background:var(--amber-d);border-color:rgba(245,158,11,.25);color:var(--amber)}

/* CHAT */
.chat-wrap{height:calc(100vh - 300px);min-height:280px;overflow-y:auto;display:flex;flex-direction:column;gap:12px;padding:16px;background:var(--bg3);border:1px solid var(--bd);border-radius:var(--r);margin-bottom:12px}
.msg{display:flex;gap:8px;max-width:85%}
.msg.me{align-self:flex-end;flex-direction:row-reverse}
.msg-av{width:28px;height:28px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;font-family:'Cormorant Garamond',serif}
.msg-av.ai{background:linear-gradient(135deg,var(--g),var(--gd));color:var(--n)}
.msg-av.me{background:var(--n2);color:var(--t3);font-size:10px}
.msg-bbl{background:var(--card);border:1px solid var(--bd);border-radius:12px;padding:10px 14px;font-size:13.5px;line-height:1.65;color:var(--t)}
.msg.me .msg-bbl{background:rgba(141,198,63,0.08);border-color:rgba(141,198,63,0.2)}
.msg-time{font-size:10px;color:var(--t3);margin-top:3px}
.msg.me .msg-time{text-align:right}
.chat-input-row{display:flex;gap:8px}
.chat-input{flex:1;background:var(--card);border:1px solid var(--bd);border-radius:10px;padding:11px 14px;color:var(--t);font-size:14px;font-family:'DM Sans',sans-serif;outline:none;resize:none;height:46px;transition:border .15s}
.chat-input:focus{border-color:var(--g)}
.chat-input::placeholder{color:var(--t3)}
.chat-send{width:46px;height:46px;background:var(--g);border:none;border-radius:10px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .15s}
.chat-send:hover{background:var(--g2)}
.chat-send svg{width:16px;height:16px;fill:var(--n)}

/* COURSE CARD */
.cc{background:var(--card);border:1px solid var(--bd);border-radius:var(--r);overflow:hidden;transition:all .2s;cursor:pointer}
.cc:hover{border-color:rgba(141,198,63,0.25);transform:translateY(-3px)}
.cc-top{height:90px;display:flex;align-items:center;justify-content:center;font-size:32px}
.cc-body{padding:14px}
.cc-title{font-size:13px;font-weight:500;color:var(--t);margin-bottom:5px;line-height:1.4}
.cc-meta{display:flex;gap:8px;flex-wrap:wrap;margin-top:7px}

/* CERT */
.cert{background:linear-gradient(135deg,var(--n2),var(--card));border:1px solid rgba(141,198,63,0.2);border-radius:var(--r);padding:20px;position:relative;overflow:hidden}
.cert::after{content:'';position:absolute;top:-30px;right:-30px;width:100px;height:100px;border-radius:50%;background:var(--g);opacity:.05}
.cert-icon{width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,var(--g),var(--gd));display:flex;align-items:center;justify-content:center;font-size:18px;margin-bottom:12px;box-shadow:var(--shg)}

/* PERSONA CARD */
.persona-card{background:linear-gradient(135deg,rgba(141,198,63,0.07),rgba(139,92,246,0.06));border:1px solid rgba(141,198,63,0.2);border-radius:var(--r);padding:22px}
.persona-type{font-family:'Cormorant Garamond',serif;font-size:52px;font-weight:700;background:linear-gradient(135deg,var(--g),var(--purple));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1;letter-spacing:-1px}

/* AI LOADING */
.ai-loading{display:inline-flex;align-items:center;gap:8px;padding:10px 16px;background:var(--bg3);border:1px solid var(--bd);border-radius:var(--rs);font-size:13px;color:var(--t3);margin-top:10px}
.spin{width:14px;height:14px;border:2px solid var(--bd);border-top-color:var(--g);border-radius:50%;animation:spin .7s linear infinite;display:inline-block}
@keyframes spin{to{transform:rotate(360deg)}}
.ai-result{background:var(--bg3);border:1px solid var(--bd);border-radius:var(--r);padding:16px;margin-top:12px;font-size:14px;line-height:1.8;color:var(--t2);white-space:pre-wrap;display:none}

/* COVER LETTER */
.cl-out{background:var(--bg3);border:1px solid var(--bd);border-radius:var(--r);padding:20px;min-height:240px;font-size:14px;line-height:1.9;font-family:Georgia,serif;color:var(--t);white-space:pre-wrap}

/* SCORE ROWS */
.sc-row{display:flex;align-items:center;gap:10px;padding:7px 0;border-bottom:1px solid var(--bd)}
.sc-row:last-child{border:none}
.sc-label{font-size:12px;color:var(--t3);width:140px;flex-shrink:0}
.sc-bar{flex:1}
.sc-val{font-size:12px;font-weight:600;width:32px;text-align:right;flex-shrink:0}

/* QUICK PROMPTS */
.qp{background:var(--bg3);border:1px solid var(--bd);border-radius:var(--rs);padding:9px 13px;font-size:12px;color:var(--t3);cursor:pointer;transition:all .15s;text-align:left;font-family:'DM Sans',sans-serif;width:100%;display:block;margin-bottom:6px}
.qp:hover{border-color:var(--g);color:var(--g);background:rgba(141,198,63,0.05)}

/* UPLOAD ZONE */
.upz{border:2px dashed var(--bd);border-radius:var(--r);padding:28px;text-align:center;cursor:pointer;transition:all .2s;background:var(--bg3)}
.upz:hover{border-color:var(--g);background:rgba(141,198,63,0.04)}

/* SCORE SCALE */
.sc-input{display:flex;gap:6px;margin-top:8px}
.sc-btn{width:36px;height:36px;border-radius:var(--rs);background:var(--bg3);border:1px solid var(--bd);color:var(--t3);font-size:13px;cursor:pointer;transition:all .15s;font-family:'DM Sans',sans-serif}
.sc-btn:hover,.sc-btn.sel{background:var(--gl);border-color:var(--g);color:var(--g)}

/* TOAST */
.toast{position:fixed;bottom:24px;right:24px;background:var(--card2);border:1px solid var(--bd2);border-left:3px solid var(--g);border-radius:10px;padding:12px 18px;font-size:13px;color:var(--t);z-index:999;transform:translateX(120%);transition:transform .3s;box-shadow:var(--sh);max-width:300px}
.toast.show{transform:translateX(0)}

/* MOBILE */
@media(max-width:900px){
  .sidebar{transform:translateX(-100%)}.sidebar.open{transform:translateX(0)}
  .main{margin-left:0}
  .stats-grid{grid-template-columns:1fr 1fr}
  .g2,.gm,.gs{grid-template-columns:1fr}
  .g3{grid-template-columns:1fr 1fr}
}
@media(max-width:560px){
  .g3{grid-template-columns:1fr}
  .stats-grid{grid-template-columns:1fr 1fr}
}
</style>
</head>
<body>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<!-- ══════════════════════════════════
  AUTH SCREEN
══════════════════════════════════ -->
<div class="screen active" id="auth">
  <div class="auth-bg">
