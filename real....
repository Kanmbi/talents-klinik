// ══ CLAUDE API ══
async function callClaude(sys,usr,outEl){
  if(outEl){outEl.style.display='block';outEl.textContent='Analyzing…';outEl.style.color='var(--t3)'}
  try{
    const r=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,system:sys,messages:[{role:'user',content:usr}]})
    });
    const d=await r.json();
    const txt=d.content?.map(c=>c.text||'').join('\n')||'Unable to generate response. Please try again.';
    if(outEl){outEl.textContent=txt;outEl.style.color='var(--t2)'}
    return txt;
  }catch(e){const msg='Connection issue. Please check your internet and try again.';if(outEl){outEl.textContent=msg;outEl.style.color='var(--rose)'}return msg;}
}

function showLoading(el,msg){if(el){el.style.display='block';el.innerHTML='<span class="spin"></span> '+msg;el.style.color='var(--t3)'}}

