// ══ COACH CHAT ══
const coachHistory=[];
async function sendCoach(){
  const inp=document.getElementById('coach-input');
  const msg=inp.value.trim();if(!msg)return;
  inp.value='';
  addChatMsg(msg,'me');
  coachHistory.push({role:'user',content:msg});
  const throbber=addChatMsg('<span class="spin"></span>','ai',true);
  try{
    const r=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514',max_tokens:1000,
        system:'You are a brilliant AI Career Coach for Talents Klinik (by RésuméKlinik), a Nigerian career intelligence platform. Your candidate is an ENFJ professional targeting Senior Product Manager in Nigerian FinTech (Access Bank, Flutterwave, Interswitch), 5+ years experience in strategy and operations in Lagos, CV score 78/100, skill gaps in A/B Testing and OKRs, 2 certificates earned. You have deep knowledge of the Nigerian job market, salary bands, top employers, and recruitment culture. Give sharp, specific, actionable coaching. Be warm, direct, and use your knowledge of Nigeria specifically.',
        messages:coachHistory
      })
    });
    const d=await r.json();
    const reply=d.content?.map(c=>c.text||'').join('\n')||'Sorry, I could not process that. Please try again.';
    if(throbber)throbber.remove();
    addChatMsg(reply,'ai');
    coachHistory.push({role:'assistant',content:reply});
  }catch(e){if(throbber)throbber.remove();addChatMsg('Connection issue. Please check your internet and try again.','ai');}
}

function addChatMsg(txt,role,raw=false){
  const c=document.getElementById('chat-msgs');
  const d=document.createElement('div');
  d.className='msg'+(role==='me'?' me':'');
  const avLabel=role==='ai'?'TK':'You';
  const bbl=raw?txt:txt.replace(/\n/g,'<br>');
  d.innerHTML=role==='ai'
    ?`<div class="msg-av ai">${avLabel}</div><div><div class="msg-bbl">${bbl}</div><div class="msg-time">AI Coach · Just now</div></div>`
    :`<div class="msg-av me">${avLabel}</div><div><div class="msg-bbl">${bbl}</div></div>`;
  c.appendChild(d);c.scrollTop=c.scrollHeight;
  return d;
}

function injectChat(t){document.getElementById('coach-input').value=t;document.getElementById('coach-input').focus();}

// ══ TOAST ══
function showToast(msg,dur=3000){
  const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),dur);
}
