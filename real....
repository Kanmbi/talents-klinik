function doLogin(){
  const email=document.getElementById('li-email').value.trim();
  const pw=document.getElementById('li-pw').value;
  const err=document.getElementById('login-err');
  err.style.display='none';
  if(!email||!pw){err.textContent='Please enter your email and password.';err.style.display='block';return;}
  const users=getUsers();
  const user=users.find(u=>u.email.toLowerCase()===email.toLowerCase()&&u.password===pw);
  if(!user){err.textContent='Incorrect email or password. Please try again.';err.style.display='block';return;}
  setCurrentUser(user);
  loadApp(user);
}

function doRegister(){
  const fn=document.getElementById('rg-fn').value.trim();
  const ln=document.getElementById('rg-ln').value.trim();
  const email=document.getElementById('rg-email').value.trim();
  const phone=document.getElementById('rg-phone').value.trim();
  const role=document.getElementById('rg-role').value.trim();
  const pw=document.getElementById('rg-pw').value;
  const err=document.getElementById('reg-err2');
  err.style.display='none';
  if(!fn||!email||!pw){err.textContent='Please fill in all required fields.';err.style.display='block';return;}
  if(pw.length<8){err.textContent='Password must be at least 8 characters.';err.style.display='block';return;}
  const users=getUsers();
  if(users.find(u=>u.email.toLowerCase()===email.toLowerCase())){err.textContent='An account with this email already exists. Please sign in.';err.style.display='block';return;}
  const user={fn,ln,email,phone,role,password:pw,created:new Date().toISOString(),initials:(fn[0]+(ln?ln[0]:'')).toUpperCase()};
  users.push(user);
  saveUsers(users);
  setCurrentUser(user);
  showToast('Account created successfully! Welcome to Talents Klinik.');
  loadApp(user);
}

function loadApp(user){
  const name=user.fn+(user.ln?' '+user.ln:'');
  document.getElementById('su-name').textContent=name;
  document.getElementById('su-av').textContent=user.initials||user.fn[0].toUpperCase();
  document.getElementById('dash-welcome').textContent='Welcome back, '+user.fn;
  document.getElementById('welcome-name' in document.getElementById('dash-welcome') ? 'dash-welcome' : 'dash-welcome').textContent='Welcome back, '+user.fn;
  showScreen('app');
}

function logout(){
  sessionStorage.removeItem('tk_user');
  showScreen('auth');
  document.getElementById('li-email').value='';
  document.getElementById('li-pw').value='';
  document.getElementById('login-err').style.display='none';
}

// Auto-login
window.addEventListener('DOMContentLoaded',()=>{
  const u=getCurrentUser();
  if(u) loadApp(u);
});

